<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) splash screen overrides.

  On Android 12+, the system ignores `android:windowBackground` for the
  cold-start splash and instead renders its own surface driven by the
  `windowSplashScreen*` theme attributes. Without these overrides the
  splash falls back to white; we point it at the brand colour and the
  launcher icon to match Android 8–11 behaviour.
-->
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/ic_launcher_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
